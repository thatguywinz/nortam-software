# ─────────────────────────────────────────────────────────────────────────
# Nortam Assure — environment configuration
# Copy this file to `.env` for local development. Nothing here is required to
# run locally: with no values changed, the app uses a local SQLite database and
# a deterministic local translation generator (no API keys needed).
# ─────────────────────────────────────────────────────────────────────────

# --- Local database (development) -----------------------------------------
# File-based SQLite — no external server. The schema + demo data are created
# automatically on first run, so you can just `npm run dev`.
DATABASE_URL="file:./dev.db"

# --- Production database (Turso / libSQL) ----------------------------------
# Leave BLANK for local development. When these are set (e.g. on Vercel), the
# app connects to a serverless-friendly Turso database instead of the local
# file, and self-provisions its schema + demo data on first access.
# Create a free database at https://turso.tech then run:
#   turso db create nortam-assure
#   turso db show nortam-assure --url        # -> TURSO_DATABASE_URL
#   turso db tokens create nortam-assure     # -> TURSO_AUTH_TOKEN
TURSO_DATABASE_URL=""
TURSO_AUTH_TOKEN=""

# --- Authentication (NextAuth) ---------------------------------------------
# Generate a strong secret with:  openssl rand -base64 48
NEXTAUTH_SECRET="replace-with-strong-random-string"
# Local: http://localhost:3000   Production: https://your-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# --- AI first-draft translation --------------------------------------------
# Options: "anthropic", "openai", "auto", or "mock".
# Leave ANTHROPIC_API_KEY blank to use the built-in deterministic local draft
# generator — the app stays fully functional with zero API keys / zero cost.
AI_PROVIDER="anthropic"
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"
OPENAI_API_KEY=""
