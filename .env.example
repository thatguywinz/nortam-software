# Local development uses a file-based SQLite database — no external server needed.
# `npx prisma db push` creates the file at prisma/dev.db.
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_SECRET="replace-with-strong-random-string"
# Local: http://localhost:3000   Production: https://your-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# AI translation provider. Options: "anthropic", "openai", "auto", or "mock".
# Paste an ANTHROPIC_API_KEY to get real Claude translations; blank = local fallback.
AI_PROVIDER="anthropic"
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"
OPENAI_API_KEY=""
